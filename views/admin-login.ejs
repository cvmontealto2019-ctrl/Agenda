<%- include('partials/head') %>
<main class="login">
  <form method="post" action="/agendadecoracao/login">
    <img src="<%= s.logo_url || '/public/assets/logo.svg' %>" alt="Biruta Park" style="width:110px;display:block;margin:0 auto 14px">
    <h1>Agenda de Decoração</h1>
    <p class="muted">Acesso interno para controle de festas, temas e horários.</p>
    <% if(error){ %><p class="error"><%= error %></p><% } %>
    <label>Login<input name="login" autocomplete="username" required></label>
    <label>Senha<input type="password" name="password" autocomplete="current-password" required></label>
    <button class="btn" type="submit">Entrar</button>
  </form>
</main>
</body>
</html>
