<%- include('partials/head') %>
<main class="agenda-shell">
  <header class="agenda-top">
    <div>
      <img src="<%= s.logo_url || '/public/assets/logo.svg' %>" alt="Biruta">
      <h1>Usuários da Agenda</h1>
      <p>Controle exclusivo da agenda de decoração</p>
    </div>
    <nav>
      <a href="/agendadecoracao">Início</a>
      <a href="/agendadecoracao/calendario">Calendário</a>
      <a href="/agendadecoracao/relatorio">Relatório</a>
      <a href="/agendadecoracao/logout">Sair</a>
    </nav>
  </header>

  <section class="card">
    <h2>Criar novo usuário</h2>
    <form class="form-grid uppercase-form" method="post" action="/agendadecoracao/usuarios">
      <input name="name" placeholder="NOME">
      <input name="login" placeholder="Login">
      <input name="password" placeholder="Senha">
      <select name="role">
        <option value="admin">Administrador da agenda</option>
        <option value="equipe">Equipe - cadastra e edita</option>
        <option value="visualizacao">Visualização</option>
      </select>
      <button class="btn" type="submit">Adicionar usuário</button>
    </form>
  </section>

  <section class="card">
    <h2>Usuários cadastrados</h2>
    <div class="table">
      <table>
        <thead><tr><th>Nome</th><th>Login</th><th>Nível</th><th>Editar</th></tr></thead>
        <tbody>
          <% users.forEach(u=>{ %>
            <tr>
              <td><%= u.name %></td>
              <td><%= u.login %></td>
              <td><%= u.role %></td>
              <td>
                <form class="inline-edit uppercase-form" method="post" action="/agendadecoracao/usuarios">
                  <input type="hidden" name="id" value="<%= u.id %>">
                  <input name="name" value="<%= u.name %>">
                  <input name="login" value="<%= u.login %>">
                  <input name="password" placeholder="Nova senha opcional">
                  <select name="role">
                    <option value="admin" <%= u.role==='admin' ? 'selected' : '' %>>Administrador</option>
                    <option value="equipe" <%= u.role==='equipe' ? 'selected' : '' %>>Equipe</option>
                    <option value="visualizacao" <%= u.role==='visualizacao' ? 'selected' : '' %>>Visualização</option>
                  </select>
                  <button class="btn tiny" type="submit">Salvar</button>
                </form>
                <form method="post" action="/agendadecoracao/usuarios/<%= u.id %>/delete" onsubmit="return confirm('Excluir usuário?')">
                  <button class="danger" type="submit">Excluir</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</main>
<script>
document.querySelectorAll('.uppercase-form input[name="name"]').forEach(el => {
  el.addEventListener('input', () => { el.value = el.value.toLocaleUpperCase('pt-BR'); });
});
</script>
</body>
</html>
